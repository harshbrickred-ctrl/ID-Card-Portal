# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/id_card_portal

# Session JWT (32+ characters)
JWT_SECRET=change-me-to-at-least-32-characters-long

# Public portal URL
PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001

# Vercel Blob — on Vercel, BLOB_STORE_ID is set when you connect a Blob store (OIDC auth).
# For local uploads to Blob, run `vercel env pull` or set BLOB_READ_WRITE_TOKEN.
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=
