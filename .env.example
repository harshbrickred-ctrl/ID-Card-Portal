# Portal database (Neon Postgres — separate from Vetan)
DATABASE_URL=postgresql://user:pass@host/id_card_portal?sslmode=require

# Portal session JWT
JWT_SECRET=change-me-to-at-least-32-characters-long

# SSO secrets per SaaS source (JSON map)
JWT_SECRETS={"vetan":"same-secret-as-vetan-ID_CARD_PORTAL_JWT_SECRET"}

# Public portal URL
PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001

# Optional: Vercel Blob for logos, photos, ZIP exports
BLOB_READ_WRITE_TOKEN=
