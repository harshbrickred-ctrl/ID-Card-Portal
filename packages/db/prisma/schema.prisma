generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model School {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  address     String?
  logoUrl     String?
  accentColor String   @default("#CCC3D0")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students  Student[]
  template  IdCardTemplate?
  printJobs PrintJob[]
}

model Student {
  id         String   @id @default(uuid())
  schoolId   String
  enrollId   String
  name       String
  class      String
  section    String
  fatherName String?
  motherName String?
  dob        String?
  bloodGroup String?
  address    String?
  photoUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  school     School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  printItems PrintJobItem[]

  @@unique([schoolId, enrollId])
  @@index([schoolId, class, section])
  @@index([schoolId, name])
}

model IdCardTemplate {
  id        String   @id @default(uuid())
  schoolId  String   @unique
  name      String
  filePath  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model PrintJob {
  id        String   @id @default(uuid())
  schoolId  String
  cardCount Int
  createdAt DateTime @default(now())

  school School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  items  PrintJobItem[]
}

model PrintJobItem {
  id        String @id @default(uuid())
  jobId     String
  studentId String

  job     PrintJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([jobId, studentId])
}
